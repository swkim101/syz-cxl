{
    "target": "linux/amd64",
    "http": "0.0.0.0:56900",
    "workdir": "workdir",
    "kernel_obj": "<path>",
    "image": "<path>",
    "syzkaller": ".",
    "procs": 4,
    "type": "qemu",
    "sshkey": "<path>",
    "vm": {
        "qemu": "qemu-system-x86_64",
        "raw_args": "-object memory-backend-file,id=cxl-mem1,share=on,mem-path=/tmp/cxltest{{INDEX}}.raw,size=256M -object memory-backend-file,id=cxl-lsa1,share=on,mem-path=/tmp/lsa{{INDEX}}.raw,size=256M -device pxb-cxl,bus_nr=12,bus=pcie.0,id=cxl.1 -device cxl-rp,port=0,bus=cxl.1,id=root_port13,chassis=0,slot=2 -device cxl-type3,bus=root_port13,persistent-memdev=cxl-mem1,lsa=cxl-lsa1,id=cxl-pmem0,sn=0x1 -M q35,cxl=on,cxl-fmw.0.targets.0=cxl.1,cxl-fmw.0.size=4G",
        "count": 4,
        "kernel": "<path>",
        "cpu": 2,
        "mem": 8192
    },
    "enable_syscalls": [
        "openat$cxl_flush",
        "write$cxl_flush",
        "openat$cxl_devices_dir",
        "openat$cxl_mem_attr",
        "read$cxl_mem_attr",
        "openat$cxl_mem_dir",
        "openat$cxl_root_attr",
        "read$cxl_root_attr",
        "openat$cxl_root_dir",
        "openat$cxl_port_attr",
        "read$cxl_port_attr",
        "openat$cxl_port_dir",
        "openat$cxl_endpoint_attr",
        "read$cxl_endpoint_attr",
        "openat$cxl_endpoint_dir",
        "openat$cxl_decoder_attr_r",
        "read$cxl_decoder_attr",
        "openat$cxl_switch_decoder_attr_r",
        "read$cxl_switch_decoder_attr",
        "openat$cxl_create_pmem_region_r",
        "read$cxl_create_region",
        "openat$cxl_create_pmem_region_w",
        "write$cxl_create_pmem_region",
        "openat$cxl_delete_region",
        "write$cxl_delete_region",
        "openat$cxl_region0_attr_r",
        "openat$cxl_region1_attr_r",
        "read$cxl_region_attr",
        "openat$cxl_region_interleave_granularity_w",
        "write$cxl_region_interleave_granularity",
        "openat$cxl_region_interleave_ways_w",
        "write$cxl_region_interleave_ways",
        "openat$cxl_region_uuid_w",
        "write$cxl_region_uuid",
        "openat$cxl_region_size_w",
        "write$cxl_region_size",
        "openat$cxl_region_commit_w",
        "write$cxl_region_commit",
        "openat$cxl_ep_decoder_attr_r",
        "read$cxl_ep_decoder_attr",
        "openat$cxl_ep_decoder_dpa_size_w",
        "write$cxl_ep_decoder_dpa_size",
        "openat$cxl_ep_decoder_mode_w",
        "write$cxl_ep_decoder_mode",
        "openat$cxl_ndctl_attr",
        "read$cxl_ndctl_attr",
        "openat$cxl_ndctl_region_attr",
        "read$cxl_ndctl_region_attr",
        "openat$cxl_ndctl_deep_flush",
        "write$cxl_ndctl_deep_flush",
        "read$cxl_ndctl_deep_flush",
        "openat$cxl_sysfs",
        "mmap",
        "munmap",
        "close"
    ]
}
